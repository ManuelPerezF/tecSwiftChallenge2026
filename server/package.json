{
  "name": "kuidar-server",
  "version": "1.0.0",
  "description": "Kuidar REST API — Express + SQLite + TypeScript",
  "type": "module",
  "main": "src/app.ts",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/app.ts",
    "start": "tsx src/app.ts",
    "build": "tsc"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "uuid": "^11.1.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
